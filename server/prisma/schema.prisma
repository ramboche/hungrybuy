generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum Role {
  USER
  SHOP
  ADMIN
}

model User {
  id       String  @id @default(uuid())
  phone    String? @unique
  email    String? @unique
  name     String
  password String?
  role     Role    @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
