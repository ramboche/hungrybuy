generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum Role {
  USER
  SHOP
  ADMIN
}

enum FoodType {
  VEG
  NON_VEG
}

enum OrderStatus {
  PENDING
  CANCELLED
  SERVED
  PAID
}

model User {
  id       String  @id @default(uuid())
  phone    String? @unique
  email    String? @unique
  name     String
  password String?
  role     Role    @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id      String @id @default(uuid())
  number  Int    @unique
  qrToken String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id    String     @id @default(uuid())
  name  String     @unique
  items MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  foodType    FoodType
  price       Decimal? @db.Decimal(10, 2)
  isAvailable Boolean  @default(true)
  image       String?
  rating      Float    @default(0)
  ratingCount Int      @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  variants   MenuVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([foodType])
}

model MenuVariant {
  id    String  @id @default(uuid())
  label String
  price Decimal @db.Decimal(10, 2)
  image String?

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAT DateTime @updatedAt

  @@unique([menuItemId, label])
  @@index([menuItemId])
}

model CartItem {
  id      String @id @default(uuid())
  tableId String

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  variantId String?
  variant   MenuVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  createdAt DateTime @default(now())

  @@unique([tableId, menuItemId, variantId])
  @@index([tableId])
}

model Order {
  id          String      @id @default(uuid())
  tableId     String
  status      OrderStatus @default(PENDING)
  isActive    Boolean     @default(true)
  totalAmount Decimal     @default(0) @db.Decimal(10, 2)

  items OrderItem[]

  createdAt DateTime @default(now())

  @@index([tableId])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  variantId String?
  variant   MenuVariant? @relation(fields: [variantId], references: [id])

  quantity Int
  price    Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
}
