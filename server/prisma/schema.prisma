generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum Role {
  CUSTOMER
  RESTAURANT_OWNER
  PLATFORM_ADMIN
}

enum FoodType {
  VEG
  NON_VEG
  DRINKS
  SNACKS
  DESSERTS
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  CANCELLED
  SERVED
  PAID
}

model User {
  id       String  @id @default(uuid())
  phone    String? @unique
  email    String? @unique
  name     String
  password String?
  role     Role    @default(CUSTOMER)

  authSessions AuthSession[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurants Restaurant[]
}

model AuthSession {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessTokenHash  String
  refreshTokenHash String

  accessExpiry  DateTime
  refreshExpiry DateTime

  revoked Boolean @default(false)

  userAgent String?
  ipAddress String?

  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Restaurant {
  id          String  @id @default(uuid())
  name        String
  description String?
  logo        String?
  isActive    Boolean @default(true)
  isVerified  Boolean @default(false)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  tables     Table[]
  categories Category[]
  orders     Order[]
  cartItems  CartItem[]
  menuItems  MenuItem[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  menuVariants MenuVariant[]

  @@index([ownerId])
}

model Table {
  id      String @id @default(uuid())
  number  Int
  qrToken String @unique

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  orders Order[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cartItems CartItem[]

  @@unique([restaurantId, number])
  @@index([restaurantId])
}

model Category {
  id    String  @id @default(uuid())
  name  String
  image String?

  items MenuItem[]

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  foodType    FoodType
  price       Decimal? @db.Decimal(10, 2)
  isAvailable Boolean  @default(true)
  image       String?
  rating      Float    @default(0)
  ratingCount Int      @default(0)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  variants   MenuVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([foodType])
}

model MenuVariant {
  id    String  @id @default(uuid())
  label String
  price Decimal @db.Decimal(10, 2)
  image String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAT DateTime @updatedAt

  @@unique([menuItemId, label])
  @@index([restaurantId])
  @@index([menuItemId])
}

model CartItem {
  id String @id @default(uuid())

  tableId String
  table   Table  @relation(fields: [tableId], references: [id])

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  variantId String?
  variant   MenuVariant? @relation(fields: [variantId], references: [id])

  quantity Int

  createdAt DateTime @default(now())

  @@unique([restaurantId, tableId, menuItemId, variantId])
  @@index([restaurantId])
  @@index([tableId])
}

model Order {
  id          String      @id @default(uuid())
  status      OrderStatus @default(PENDING)
  isActive    Boolean     @default(true)
  totalAmount Decimal     @default(0) @db.Decimal(10, 2)

  items OrderItem[]

  tableId String
  table   Table  @relation(fields: [tableId], references: [id])

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([restaurantId])
  @@index([tableId])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  variantId String?
  variant   MenuVariant? @relation(fields: [variantId], references: [id])

  quantity Int
  price    Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
}
